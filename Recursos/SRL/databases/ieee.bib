  doi = {10.1109/ICSCN67106.2025.11308337},
  isbn = {979-8-3315-9420-6},
  publisher = {IEEE},
  abstract = {Asthma is a chronic respiratory disorder that requires precise severity assessment to inform individualized therapy and enhance patient outcomes. This paper presents a prediction model based on an Artificial Neural Network (ANN) to classify asthma severity into mild, moderate, and severe categories utilizing clinical data. The study used a publicly available Kaggle dataset of 10,000 patient records, which encompassed demographic details, symptom profiles, lung function test metrics such as FEV1 and FVC, allergen exposure, and drug utilization. Data pretreatment encompassed normalization and one-hot encoding to provide uniformity and appropriateness for training. A feedforward ANN with two hidden layers of 128 and 64 neurons was developed, trained with the Adam optimizer and category cross-entropy loss function. The model attained an accuracy of 93.5\% on the test dataset, indicating substantial predictive dependability. Validation was performed by cross-validation and evaluated using performance measures such as accuracy, recall, and F1-score, hence assuring robustness. The findings highlight that ANN models provide a robust, data-centric methodology for classifying asthma severity, enhancing decision-making in respiratory treatment and facilitating the development of advanced clinical decision support systems.},
