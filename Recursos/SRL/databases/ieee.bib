  title = {Power Quality Enhancement of Hybrid Renewable Energy Systems Using Fuzzy Logic Controller},
  author = {S. Bihari and R. Narhete and S. Narhete},
  booktitle = {2024 IEEE 2nd International Conference on Innovations in High Speed Communication and Signal Processing (IHCSP)},
  year = {2024},
  pages = {1--6},
  doi = {10.1109/IHCSP63227.2024.10960103},
  isbn = {979-8-3503-6894-9},
  publisher = {IEEE},
  abstract = {With the continuous increase in energy demand due to industrialization, environmental challenges such as global temperature rise and air pollution have become acute. Integrating renewable energy sources (RES) into the power grid offers a sustainable solution to these issues. Traditional passive methods, such as under/overvoltage and under/over-frequency techniques, can manage power imbalances between loads and distributed generation (DG), but they struggle to detect power quality issues when supply and consumption are balanced. This paper presents a new approach to optimize power quality(PQ) in hybrid renewable energy systems using fuzzy logic controllers(FLC), in combination with inverters and maximum power point tracking (MPPT) techniques. While RES are being rapidly adopted due to their stability, their output is highly variable depending on weather conditions, which can result in power quality challenges. The FLC dynamically adjusts the parameters of the inverter and MPPT based on real-time voltage and current inputs, ensuring that the system constantly operates at its maximum power point. The inverter converts the generated DC power to AC power, making it suitable for grid integration. Simulation results demonstrate that this method enhances power quality by reducing output fluctuations, leading to a more stable and reliable power supply. Moreover, the proposed approach is easy to implement and can be adapted to various renewable energy systems, significantly improving system stability, optimizing power quality and reducing harmonic distortion.},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=10960103},
