  title = {IoT-based Design and Simulation of Smart Greenhouse Monitoring and Control System},
  author = {D. Bisht and A. Mittal},
  booktitle = {2025 7th International Conference on Inventive Material Science and Applications (ICIMA)},
  year = {2025},
