  isbn = {979-8-3315-5389-0},
  issn = {2377-5696},
  publisher = {IEEE},
  abstract = {This paper presents a machine learning framework for urban air quality analysis, combining traditional machine learning, fuzzy logic, and biomimetic pattern recognition. Our system processes real-time environmental sensor data including Nitrous Oxide (NO2) and Carbon Monoxide (CO), to predict Air Quality Index (AQI) values, reaching a 96\% \$R\^{}\{2\}\$ score. The proposed ensemble architecture integrates nine machine learning models, including Decision Trees (DT) Adaptive NeuroFuzzy Inference Systems (ANFIS) Biomimetic Neural Networks (BMN), and Feed-Forward Neural Networks (FFNN), demonstrating superior performance of the ensemble when compared to individual models across 10 randomized train-test splits. The experimental results reveal that our hybrid approach significantly reduces prediction variance compared to conventional singlemodel implementations. The research particularly highlights the effectiveness of combining symbolic AI (fuzzy logic, biomimetic networks) with subsymbolic approaches (neural networks and machine learning) for handling sensor data uncertainties. Finally, the predictive pipeline could potentially be integrated into monitoring stations to improve risk assessment capabilities, and could also be applied to assess air quality in localized areas.},
