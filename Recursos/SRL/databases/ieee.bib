@inproceedings{A2025Multi,
  title = {Multi-Stage Context-Aware IoT Architecture with Genetic Feature Selection and Neural XGBoost Prediction},
  author = {R. A and N. N. Prabhu and S.Nithesh and R. M. Ashik and M. N. Kumar},
  booktitle = {2025 International Conference on Recent Innovation in Science Engineering and Technology (ICRISET)},
  year = {2025},
  pages = {1--9},
  doi = {10.1109/ICRISET64803.2025.11252314},
  isbn = {979-8-3315-5833-8},
  publisher = {IEEE},
  abstract = {The exponential growth of Internet of Things (IoT) ecosystems has led to significant challenges in real-time, context-aware sensor ranking for mission-critical applications. This study proposes a Multi-Stage Context-Aware IoT Architecture that integrates genetic correlation-based feature selection with a Neural-Enhanced XGBoost (N-XGBoost) prediction model to achieve high-accuracy, low-latency sensor ranking. The architecture begins with IoT data acquisition from heterogeneous sensors—covering environmental, location, motion, and operational parameters—followed by preprocessing for data cleaning, normalization, and temporal segmentation. Fuzzy C-Means clustering is used to group sensors based on contextual similarity, while fuzzy logic-based defeasible reasoning resolves conflicting rankings in overlapping contexts. Genetic feature selection eliminates redundant attributes, ensuring optimal input dimensionality for the N-XGBoost model, which combines deep neural networks for complex feature interaction capture with gradient-boosted decision trees for robust ranking predictions. Experimental evaluation on a real-world IoT dataset demonstrates an accuracy of 98.21\%, achieving a 12.7\% latency reduction and a 15.4\% RMSE improvement over state-of-the-art methods, including Adaptive Bayesian Networks, Dynamic Skyline Techniques, and Greatest of Actual Time (GoAT). Compared to the Random Neural XGBoost baseline, the proposed model improves accuracy by 1.18\% and reduces prediction error by 9.6\%. The results highlight its applicability in smart cities, healthcare monitoring, and industrial automation, where adaptive and accurate sensor prioritization is essential. This framework represents a significant advancement in context-aware IoT analytics, offering both improved predictive performance and scalability in dynamic, high-density deployments.},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11252314},
  date_added_to_xplore = {28 Nov 2025},
  online_date = {28 Nov 2025},
  issue_date = {1-2 Aug. 2025},
  meeting_date = {1-2 Aug. 2025},
  author_affiliations = {Department of Cyber Security, Mahendra Engineering College, Namakkal; Department of Cyber Security, Mahendra Engineering College, Namakkal; Department of Cyber Security, Mahendra Engineering College, Namakkal; Department of Cyber Security, Mahendra Engineering College, Namakkal; Department of Cyber Security, Mahendra Engineering College, Namakkal},
  author_keywords = {Internet of Things;Context-Aware Computing;Genetic Feature Selection;Neural XGBoost;Sensor Ranking;Fuzzy Logic;IoT Analytics;Real-Time Prediction;Edge Computing;Machine Learning},
  ieee_terms = {Adaptation models;Technological innovation;Accuracy;Smart cities;Computer architecture;Predictive models;Genetics;Feature extraction;Real-time systems;Internet of Things},
  reference_count = {14.0},
  license = {IEEE},
