  author_keywords = {Air Quality;Tsukamoto Fuzzy Logic;IoT;Embedded Systems;Real-Time Data},
  ieee_terms = {Fuzzy logic;Temperature sensors;Temperature measurement;Air quality;Real-time systems;Sensor systems;Sensors;Pollution measurement;Servers;Monitoring},
  reference_count = {20.0},
  license = {IEEE},
