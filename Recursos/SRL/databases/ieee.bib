@inproceedings{Sun2025Research,
  title = {Research on Optimizing the Environmental Control System of Horse All-Weather Walking House by Data Analysis},
  author = {Z. Sun and X. Yan},
  booktitle = {2025 IEEE 3rd International Conference on Control, Electronics and Computer Technology (ICCECT)},
  year = {2025},
  pages = {1700--1705},
  doi = {10.1109/ICCECT64621.2025.11339547},
  isbn = {979-8-3315-1855-4},
  publisher = {IEEE},
  abstract = {This paper proposes an optimization method based on data analysis, which optimizes the environmental control system of horse all-weather walking house by adaptive control algorithm to ensure accurate temperature and humidity regulation and air quality control under different climatic conditions. The system constructs a dynamic control model including multiple environmental variables such as temperature and humidity, CO2 concentration, and light, and uses multi-sensors to collect data in real time, and combines data preprocessing technology to improve data quality and accuracy. Through signal noise reduction, outlier detection and feature extraction, the system can respond quickly to environmental changes, and use adaptive control algorithms to adjust the control strategy in real time to ensure that environmental parameters are always maintained within the optimal range. The simulation results show that the optimized control system has strong adaptability in dynamic environments, among which the temperature control error is reduced from \$\\pm 2.5\^{}\{\\circ\} \\mathrm\{C\}\$ of the traditional method to \$\\pm 1.2\^{} \{\\circ\} \\mathrm\{C\}\$, and the humidity error is reduced from \$\\pm 8\\\%\$ to \$\\pm 3\\\%\$. At the same time, the adjustment stabilization time of CO2 concentration is shortened from the original 45 minutes to 30 minutes, and the adjustment response time of light intensity is reduced by 40\%. In addition, the optimized system still maintains high stability under extreme weather conditions, and the fluctuation range of temperature and humidity is reduced by about 50\%. Experimental verification shows that the method proposed in this study has significantly improved stability, accuracy and response speed compared with traditional control methods. It not only effectively improves the comfort of horses, but also provides a new direction for the research of intelligent environmental control systems.},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11339547},
