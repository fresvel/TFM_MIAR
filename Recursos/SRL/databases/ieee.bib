@inproceedings{Lauw2025IoT,
  title = {IoT-Based Air Quality Monitoring System Using Tsukamoto Fuzzy Logic},
  author = {C. M. Lauw and D. Priyanto and Husain and I. M. Y. Dharma and M. W. Alfiansyah},
  booktitle = {2025 7th International Conference on Cybernetics and Intelligent System (ICORIS)},
  year = {2025},
