  author = {S. Singh and S. Johari and G. S. Jethi},
  booktitle = {2025 International Conference on Sustainable Communication Networks and Application (ICSCN)},
  year = {2025},
  pages = {192--198},
  doi = {10.1109/ICSCN67106.2025.11308578},
  isbn = {979-8-3315-9420-6},
  publisher = {IEEE},
  abstract = {Due to resource limitations, energy limitations, and the requirement for prompt identification of anomalous behaviour, fault detection in Wireless Sensor Networks (WSNs) is a significant challenge. For real-time WSN applications, traditional cloud-based solutions are inappropriate due to their high latency and excessive communication overhead. This work suggests a fault detection framework based on Edge AI to overcome these constraints. Each sensor node analyses parameters like residual energy, packet delay, and packet delivery ratio locally. A federated learning technique is used at an edge server to further aggregate the local inferences, protecting privacy and lowering bandwidth usage. The accuracy, precision, recall, F1-score, and ROC analysis were used to assess the performance of the suggested method, which was simulated in MATLAB. The findings show that the framework attains an F1-score of 84.21\%, an accuracy of 82\%, a recall of 100\%, and an AUC value of 0.826. These results demonstrate that the suggested methodology greatly lessens dependency on cloud resources while offering dependable and effective fault detection. The framework is especially well-suited for implementation in practical IoT and WSN applications that demand prompt and energyefficient fault handling.},
  url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=11308578},
