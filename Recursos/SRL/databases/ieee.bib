  author_keywords = {Energy optimization;greenhouse;inference mechanism;open connectivity foundation (OCF) IoTivity;optimization problems},
  ieee_terms = {Green products;Air pollution;Internet of Things;Actuators;Standards;Optimization;Energy consumption},
  article_citation_count = {17.0},
