  author_keywords = {Environmental Monitoring;Fuzzy AHP-TOPSIS;IoT Protocol Selection;Multi-Criteria Decision Making;Smart Air Quality Monitoring;TOPSIS},
  ieee_terms = {Scalability;LoRaWAN;Zigbee;Air quality;Energy efficiency;Real-time systems;Internet of Things;Reliability;Environmental monitoring;Interoperability},
  reference_count = {16.0},
  license = {IEEE},
