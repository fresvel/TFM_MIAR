}
@article{Tella2024Comprehensive,
  title = {A Comprehensive Review of Energy Management Strategies in Hybrid Electric Vehicles: Comparative Analysis and Challenges},
  author = {V. Chandra Tella and M. Alzayed and H. Chaoui},
  journal = {IEEE Access},
