Language = {English},
Affiliation = {Broday, DM (Corresponding Author), Technion IIT, Fac Civil \& Environm Engn, IL-32000 Haifa, Israel.
   Shafran-Nathan, Rakefet; Etzion, Yael; Broday, David M., Technion IIT, Fac Civil \& Environm Engn, IL-32000 Haifa, Israel.},
