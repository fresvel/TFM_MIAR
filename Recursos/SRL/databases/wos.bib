@article{ WOS:000773870500001,
Author = {Bushnag, Anas},
Title = {An improved air quality and climate control monitoring system using
   fuzzy logic for enclosed areas},
Journal = {JOURNAL OF AMBIENT INTELLIGENCE AND HUMANIZED COMPUTING},
Year = {2022},
Month = {2022 MAR 28},
Abstract = {Indoor pollution is significant for many people since it has greater
   effects than outdoor pollution. Maintaining a healthy indoor environment
   is critical. Therefore, indoor environments are ventilated to reduce
   health risks and improve air quality. In these kinds of situations,
   automation to refresh surrounding environments is important because of
   the current fast-paced lifestyles of most people. The technique proposed
   in this paper automates and manages indoor temperature, humidity, and
   air quality. This is achieved by using an Arduino microcontroller with
   fuzzy logic integration. The air quality is measured by using an MQ-135
   sensor, whereas the temperature and humidity of the indoor environment
   are tracked by using a DHT-11 sensor. These sensors transmit their
   readings to a microcontroller to set the ventilation speed for the
   indoor environment, which removes harmful gases and maintains acceptable
   temperature and humidity levels. The performance of the proposed system
   shows excellent results in controlling and monitoring air quality,
   temperature, and humidity compared with a previous version due to an
   increased range between the minimum and maximum values of the
   ventilation speed. Moreover, the ventilation DC motor of the fan in the
   proposed system runs at low speeds when necessary, which leads to lower
   power consumption compared to the previous version. This reduction is
   due to the membership function added to the ventilation speed of the
   fuzzy controller, which adapts the working time interval and room
   ventilation speed. A comparison of the new proposed system and previous
   version is conducted to identify the differences between the two and to
   highlight the effectiveness of the new model.},
