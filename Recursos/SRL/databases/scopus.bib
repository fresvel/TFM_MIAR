@ARTICLE{Kumar202543446,
	author = {Kumar, Deepak and Talukdar, Nayanjit and Ghosh, Arindam and Mazumdar, Nabajyoti and Kumar Singh, Rajat},
	title = {Fuzzy Logic-Inspired Dynamic Energy Optimization Mechanism for Resource-Constrained IoT Sensor Nodes With Renewable Power Sources},
	year = {2025},
	journal = {IEEE Sensors Journal},
	volume = {25},
	number = {23},
	pages = {43446 - 43458},
	doi = {10.1109/JSEN.2025.3623795},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105020397655&doi=10.1109%2FJSEN.2025.3623795&partnerID=40&md5=50f1ddaa7f87276c49f463aaf37c9386},
	affiliations = {Indian Institute of Information Technology, Allahabad, Prayagraj, UP, India},
	abstract = {Energy sustainability remains a critical challenge in Internet of Things (IoT) networks, where sensor nodes are inherently constrained by limited battery capacity. Energy harvesting (EH) has emerged as a viable solution, enabling sensor nodes to replenish power from ambient sources such as solar radiation and radio frequency (RF) signals. However, the stochastic and intermittent nature of harvested energy poses significant challenges to conventional routing schemes that assume stable energy availability. This work proposes a fuzzy logic-based adaptive routing and positioning framework designed for EH-enabled IoT networks to ensure balanced energy utilization and resilient connectivity. The framework operates through two key phases: 1) strategic placement of EH nodes guided by contextual parameters such as residual energy, node density, and solar intensity; and 2) energy-aware routing that dynamically selects optimal communication paths based on link quality and node energy levels. By leveraging the decision-making flexibility of fuzzy logic, the system adapts in real time to fluctuating energy conditions, enhancing network longevity and reliability. Extensive simulations demonstrate that the proposed framework significantly improves energy efficiency, network sustainability, and data delivery performance compared to conventional routing approaches, highlighting its potential for large-scale, energy-constrained IoT deployments. © 2001-2012 IEEE.},
	author_keywords = {Energy harvesting (EH); fuzzy logic; Internet of Things (IoT); routing protocols},
