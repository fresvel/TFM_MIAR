	title = {Soft computing techniques for atmospheric pollution and traffic emission prediction},
	year = {2026},
	journal = {Environmental Modelling and Software},
	volume = {197},
	pages = {},
	doi = {10.1016/j.envsoft.2025.106828},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105025012854&doi=10.1016%2Fj.envsoft.2025.106828&partnerID=40&md5=da8552a10d5d883a4064354ceeaf9c16},
	affiliations = {Amity University, Noida, UP, India; Amity University, Noida, UP, India},
	abstract = {Air pollution, especially from traffic emissions, poses a significant threat to public health and environmental sustainability. Traditional monitoring systems are resource-intensive, prompting a shift toward computational forecasting techniques. This mini-review evaluates the application of soft computing methods—such as Artificial Neural Networks (ANN), Fuzzy Logic, Genetic Algorithms, and hybrid models—for atmospheric pollution and traffic emission prediction. These models offer flexibility, adaptability, and high accuracy in handling nonlinear and uncertain data. The review compares model architectures, input features, and performance metrics, emphasizing the superior predictive ability of hybrid and deep learning models. Additionally, the potential integration of these models with IoT and smart city frameworks is discussed. Key limitations, including lack of model generalizability and uncertainty handling, are highlighted alongside suggestions for future improvement. This work provides a concise overview of emerging data-driven strategies for air quality forecasting, offering direction for researchers and policymakers in sustainable urban planning. © 2025 Elsevier Ltd},
	author_keywords = {Artificial neural network; Atmospheric pollution forecasting; Computational approach; Genetic algorithm; Machine learning; Traffic emission},
	keywords = {Air quality; Data handling; Deep learning; Fuzzy logic; Fuzzy neural networks; Learning algorithms; Learning systems; Public health; Soft computing; Sustainable development; Uncertainty analysis; Urban planning; Weather forecasting; Atmospheric pollution; Atmospheric pollution forecasting; Computational approach; Emissions prediction; Environmental sustainability; Machine-learning; Neural-networks; Pollution emissions; Softcomputing techniques; Traffic emissions; Genetic algorithms; accuracy assessment; air quality; artificial neural network; atmospheric pollution; fuzzy mathematics; genetic algorithm; pollution monitoring; traffic emission; urban planning},
	correspondence_address = {D. Srivastava; Amity University Uttar Pradesh, Lucknow, Lucknow Campus, Uttar Pradesh, 226010, India; email: dsrivastava4@lko.amity.edu; J. Pandey; Amity University Uttar Pradesh, Lucknow, Lucknow Campus, Uttar Pradesh, 226010, India; email: jpandey@lko.amity.edu; V. Mishra; Amity Institute of Click Chemistry Research and Studies, Amity University Uttar Pradesh, Noida Campus, Uttar Pradesh, 201313, India; email: vmishra@amity.edu},
