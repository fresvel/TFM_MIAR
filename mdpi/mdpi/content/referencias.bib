@ARTICLE{A114,
	author = {Sung, Weii Tsai and Aryani, Jenny and Sung-Jung, Hsiao},
	title = {Intelligent Factory with Environment Quality Control Based on Fuzzy Method through Deep Reinforcement Learning},
	year = {2024},
	journal = {Sensors and Materials},
	volume = {36},
	number = {8},
	pages = {3491 - 3517},
	doi = {10.18494/SAM4661},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85202751409&doi=10.18494%2FSAM4661&partnerID=40&md5=8b0c1e9ecc69b706b8604360e4faa639},
	affiliations = {National Chin-Yi University of Technology, Department of Electrical Engineering, Taichung, Taiwan; Takming University of Science and Technology, Department of Information Technology, Taipei, Taipei, Taiwan},
	abstract = {This study is aimed at developing an intelligent factory control system for improving environment quality and reducing electricity consumption. By automating intelligent equipment and leveraging internet networks, the system enables the remote monitoring and management of environmental conditions. We combine the fuzzy method and deep reinforcement learning (DRL) to handle complex factory data and optimize decision-making. The fuzzy method uses fuzzy sets and rules to generate accurate outputs from the data. On the other hand, the DRL system learns optimal policies by interacting with the environment using environment quality, central air conditioner (AC), and alarm data. Hardware implementation uses an ESP32-S microcontroller to send data to Google’s Firebase cloud for seamless management and monitoring through a mobile app or website. The study involves developing 36 fuzzy rules and creating 10 models with different combinations of hidden layers, epochs, and learning rate values. Among the fuzzy inference system (FIS)-DRL modeling results, the fourth model stands out as the preferred option to proceed with the experiment, as it achieves the highest accuracy of 91.16%. Note that this model also exhibits a loss value of 1.64% and an incredibly short inference time of only 3 ms. The proposed system offers benefits such as enhanced energy efficiency and reduced costs, making it ideal for intelligent factories. By optimizing resource usage, it will contribute to sustainable development in various industries. © MYU K.K.},
	author_keywords = {deep reinforcement learning; environment quality system; fuzzy method; Internet of Things (IoT)},
	keywords = {Decision making; Fuzzy rules; Reinforcement learning; Smart manufacturing; Electricity-consumption; Environment quality; Environment quality system; Factory control; Fuzzy methods; Intelligent equipment; Internet of thing; Quality systems; Reinforcement learnings; Remote monitoring; Deep reinforcement learning},
	correspondence_address = {S.-J. Hsiao; Department of Information Technology, Takming University of Science and Technology, Taipei City, No. 56, Sec. 1, Huanshan Rd., Neihu District, 11451, Taiwan; email: sungjung@gs.takming.edu.tw},
	publisher = {M Y U Scientific Publishing Division},
	issn = {09144935},
	language = {English},
	abbrev_source_title = {Sens. Mater.},
	type = {Article},
