@ARTICLE{ART07,
	author = {Saleem, Muhammad and Shingari, Nitinkumar and Farooq, Muhammad Sajid and Mago, Beenu and Khan, Muhammad Adnan},
	title = {Real-Time Air Quality Monitoring Model using Fuzzy Inference System},
	year = {2024},
	journal = {International Journal of Advanced Computer Science and Applications},
	volume = {15},
	number = {6},
	pages = {838 - 846},
	doi = {10.14569/IJACSA.2024.0150684},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85198293522&doi=10.14569%2FIJACSA.2024.0150684&partnerID=40&md5=f78d46ce9c42d591d7624491e738933e},
	affiliations = {Minhaj University Lahore, School of Computer Science, Lahore, Punjab, Pakistan; Banasthali Vidyapith, Department of Computer Science, Vanasthali, RJ, India; Lahore Garrison University, Department of Computer Science, Lahore, Punjab, Pakistan; Horizon University College, School of Computing, Ajman, Ajman, United Arab Emirates; Gachon University, Department of Software, Seongnam, Gyeonggi-do, South Korea},
	abstract = {Air pollution, which is both environmental and social, is a serious issue that affects people’s health as well as ecosystems and the environment. Air pollution currently poses a number of health problems to the ecosystem. The most important factor that has a direct impact on disease occurrence and decreases people’s quality of life is city and metropolitan air quality. It is critical to establish real-time air quality monitoring in order to make timely decisions based on measurements and evaluations of environmental factors. Monitoring systems are influential in multiple smart city initiatives for keeping an eye on air quality and reducing pollutant concentrations in metropolitan areas. The Internet of Things (IoT) is becoming increasingly important in a variety of sectors, including air quality monitoring. In this research work, a real-time air quality monitoring model employing fuzzy inference is proposed for monitoring air pollution using multiple parameters such as Sulphur Dioxide (SO2), Nitrogen Dioxide (NO2), Carbon Monoxide (CO), Ozone (O3) and Suspended Particulates (PM10). This proposed research presents a novel technique for improving air quality monitoring. This proposed fuzzy inference system also provides better results in terms of monitoring air quality in a more efficient and effective way. © (2024), (Science and Information Organization). All rights reserved.},
	author_keywords = {air quality monitoring; fuzzy inference system; IoT; smart city},
	keywords = {Carbon monoxide; Ecosystems; Fuzzy systems; Internet of things; Nitrogen oxides; Smart city; Sulfur dioxide; Air quality monitoring; Decision-based; Direct impact; Environmental factors; Fuzzy inference systems; Monitoring models; Monitoring system; Pollutant concentration; Quality of life; Real- time; Air quality},
	publisher = {Science and Information Organization},
	issn = {2158107X},
	language = {English},
	abbrev_source_title = {Intl. J. Adv. Comput. Sci. Appl.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 2; All Open Access; Gold Open Access}
}


@ARTICLE{ART08,
	author = {Lingaraj, K. and Malghan, Rashmi Laxmikant and Rao, Karthik and Garg, Lalit and Somanath Swamy, R. H.M. and Vishwanatha, H. M.},
	title = {FLPSO-AMPS: an optimized WSN model for air quality monitoring in tier-2 smart cities},
	year = {2025},
	journal = {Scientific Reports},
	volume = {15},
	number = {1},
	pages = {},
	doi = {10.1038/s41598-025-19748-3},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105018817483&doi=10.1038%2Fs41598-025-19748-3&partnerID=40&md5=d1d75419309eab5d7de81771ad8dd670},
	affiliations = {Rao Bahadur Y. Mahabaleswarappa Engineering College, Department of Computer Science and Engineering, Ballari, KA, India; Manipal Institute of Technology, Manipal, KA, India; Manipal Institute of Technology, Department of Mechatronics, Manipal, KA, India; L-Università ta' Malta, Department of Computer Information Systems, Msida, Malta; Rao Bahadur Y. Mahabaleswarappa Engineering College, Department of Mechanical Engineering, Ballari, KA, India; Manipal Institute of Technology, Department of Mechanical and Industrial Engineering, Manipal, KA, India; Industrial University of Ho Chi Minh City, Faculty of Information Technology, Ho Chi Minh City, Viet Nam},
	abstract = {Wireless Sensor Networks (WSNs) are composed of small, cost-effective sensing nodes that are primarily employed for the collection of environmental data. These networks are integral to various applications including industrial pollution monitoring, disaster management, and air quality regulation. However, WSNs encounter significant challenges, such as energy efficiency, end-to-end delay, and packet loss during data transmission. Existing methodologies often fall short in optimizing the network lifespan while ensuring reliable data delivery. To address these limitations, this study introduces FLPSO-AMPS, a novel Fuzzy Logic-based Particle Swarm Optimization (FLPSO) approach aimed at enhancing energy-efficient routing in WSN-based Air Pollution Monitoring Systems (APMS) for Tier-2 smart cities. The proposed approach leverages fuzzy logic principles combined with PSO to intelligently select optimal routing paths, thereby ensuring minimal energy consumption and enhanced network longevity. Unlike conventional methodologies, FLPSO-AMPS incorporates real-time pollutant data collection and mobility-aware optimization to improve network performance. The effectiveness of FLPSO-AMPS was validated through extensive simulations, demonstrating superior performance over existing approaches, particularly with improvements of 10% in energy efficiency, 15% in task delay, 24.5% in packet delivery ratio (PDR), 11.5% in packet loss ratio (PLR), and 20.1% in throughput. These findings underscore the potential of FLPSO-AMPS in establishing an intelligent, resource-efficient air quality monitoring framework for smart cities. Future research will explore security enhancements to safeguard data transmissions in APMS networks. © The Author(s) 2025.},
	keywords = {air monitoring; air pollution; air quality; article; disaster management; energy consumption; fuzzy logic; human; longevity; particle swarm optimization; pollution monitoring; simulation},
	correspondence_address = {R.L. Malghan; Manipal Institute of Technology, Manipal Academy of Higher Education, Manipal, Karnataka, 576104, India; email: rashmi.malghan@manipal.edu; K. Rao M. C; Department of Mechatronics, Manipal Institute of Technology, Manipal Academy of Higher Education, Manipal, Karnataka, 576104, India; email: rao.karthik@manipal.edu},
	publisher = {Nature Research},
	pmid = {41093900},
	language = {English},
	abbrev_source_title = {Sci. Rep.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access; Green Accepted Open Access; Green Open Access}
}

