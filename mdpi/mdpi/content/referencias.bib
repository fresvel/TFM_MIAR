@CONFERENCE{A028,
	author = {Haidar, Imane M. and Itani, Sari S. and Kaouk, Ali and Kaddah, Ahmad and Alloul, Diyaa Abou and Doughan, Ziad},
	title = {Urban Air Quality Analysis Using Ensemble Learning},
	year = {2025},
	journal = {International Conference on Advances in Biomedical Engineering, ICABME},
	pages = {},
	doi = {10.1109/ICABME66883.2025.11211707},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105024484888&doi=10.1109%2FICABME66883.2025.11211707&partnerID=40&md5=ef4761cda0e485abcd55536b350c7db5},
	affiliations = {Beirut Arab University, Faculty of Engineering, Department of Electrical & Computer Engineering, Beirut, Lebanon},
	abstract = {This paper presents a machine learning framework for urban air quality analysis, combining traditional machine learning, fuzzy logic, and biomimetic pattern recognition. Our system processes real-time environmental sensor data including Nitrous Oxide (NO2) and Carbon Monoxide (CO), to predict Air Quality Index (AQI) values, reaching a 96% R<sup>2</sup> score. The proposed ensemble architecture integrates nine machine learning models, including Decision Trees (DT) Adaptive NeuroFuzzy Inference Systems (ANFIS) Biomimetic Neural Networks (BMN), and Feed-Forward Neural Networks (FFNN), demonstrating superior performance of the ensemble when compared to individual models across 10 randomized train-test splits. The experimental results reveal that our hybrid approach significantly reduces prediction variance compared to conventional singlemodel implementations. The research particularly highlights the effectiveness of combining symbolic AI (fuzzy logic, biomimetic networks) with subsymbolic approaches (neural networks and machine learning) for handling sensor data uncertainties. Finally, the predictive pipeline could potentially be integrated into monitoring stations to improve risk assessment capabilities, and could also be applied to assess air quality in localized areas. © 2025 IEEE.},
	author_keywords = {Biomimetic Neural Networks; Ensemble Learning; Environmental Informatics; Fuzzy Inference Systems; Machine Learning},
	keywords = {Air quality; Biomimetics; Data mining; Decision trees; Feedforward neural networks; Fuzzy inference; Fuzzy neural networks; Fuzzy systems; Learning systems; Machine learning; Nitrogen oxides; Pattern recognition; Quality control; Biomimetic neural network; Ensemble learning; Environmental Informatics; Fuzzy inference systems; Fuzzy-Logic; Learning frameworks; Machine-learning; Neural-networks; Sensors data; Urban air quality; Carbon monoxide},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
