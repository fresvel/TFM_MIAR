@ARTICLE{A168,
	author = {Preethi, K. R. and Tamilarasan, Rengasamy},
	title = {Monitoring of air pollution to establish optimal less polluted path by utilizing wireless sensor network},
	year = {2021},
	journal = {Journal of Ambient Intelligence and Humanized Computing},
	volume = {12},
	number = {6},
	pages = {6375 - 6386},
	doi = {10.1007/s12652-020-02232-3},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85086877018&doi=10.1007%2Fs12652-020-02232-3&partnerID=40&md5=8ec2240f4548d667eb22491e4a5f09a4},
	affiliations = {University College of Engineering Pattukkottai, Department of Computer Science and Engineering, Thanjavur, TN, India; University College of Engineering Pattukkottai, Department of Chemistry, Thanjavur, TN, India},
	abstract = {An efficient air pollution monitoring (APM) scheme is proposed to establish an optimal less polluted path using WSN (wireless sensor network), in which the sensor node (SN) senses the temperature and CO gas (carbon monoxide) concentration’s existent in the air. Initially, the sensed information from the SNs is preprocessed. During preprocessing, the value that is missed in the sensed information is imputed. Next, Hadoop's distributed file system (HDFS) MapReduce (MR) is implemented on the preprocessed data and subsequently, the resulting data is saved in the cloud server. The resulting data is analyzed using Improved-Adaptive Neuro-Fuzzy Inference System (I-ANFIS) Algorithm for checking air pollutions severities and its location is then presented in the Google Map. After that, the multi-path routing is established through the less polluted area. Lastly, the optimal path is chosen with the assistance of KHOA (Krill Herd Optimization Algorithm). The outcomes are evaluated by contrasting the proposed and prevailing techniques. © 2020, Springer-Verlag GmbH Germany, part of Springer Nature.},
	author_keywords = {Adaptive neuro-fuzzy inference system; Air pollution; Carbon monoxide; Krill herd optimization and MapReduce; Multi-path routing; Wireless sensor network},
	keywords = {Air pollution; Carbon monoxide; File organization; Fuzzy inference; Fuzzy neural networks; Fuzzy systems; Sensor nodes; Adaptive neuro-fuzzy inference; Adaptive neuro-fuzzy inference system; Air pollution monitoring; Carbon monoxide concentration; Distributed file systems; Krill herd optimization and mapreduce; Map-reduce; Multi-paths routing; Neuro-fuzzy inference systems; Optimisations; MapReduce},
	correspondence_address = {K. Preethi; Department of Computer Science and Engineering, University College of Engineering Pattukkottai, Thanjavur, Rajamadam, India; email: kalai.preethi@gmail.com},
