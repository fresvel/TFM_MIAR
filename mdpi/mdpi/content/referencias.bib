@ARTICLE{ART05,
	author = {Bushnag, Anas},
	title = {An improved air quality and climate control monitoring system using fuzzy logic for enclosed areas},
	year = {2023},
	journal = {Journal of Ambient Intelligence and Humanized Computing},
	volume = {14},
	number = {5},
	pages = {6339 - 6347},
	doi = {10.1007/s12652-022-03814-z},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85127252487&doi=10.1007%2Fs12652-022-03814-z&partnerID=40&md5=2e591f76d9c0f2ef7e545211f8829678},
	affiliations = {University of Tabuk, Faculty of Computers and Information Technology, Tabuk, Tabuk, Saudi Arabia},
	abstract = {Indoor pollution is significant for many people since it has greater effects than outdoor pollution. Maintaining a healthy indoor environment is critical. Therefore, indoor environments are ventilated to reduce health risks and improve air quality. In these kinds of situations, automation to refresh surrounding environments is important because of the current fast-paced lifestyles of most people. The technique proposed in this paper automates and manages indoor temperature, humidity, and air quality. This is achieved by using an Arduino microcontroller with fuzzy logic integration. The air quality is measured by using an MQ-135 sensor, whereas the temperature and humidity of the indoor environment are tracked by using a DHT-11 sensor. These sensors transmit their readings to a microcontroller to set the ventilation speed for the indoor environment, which removes harmful gases and maintains acceptable temperature and humidity levels. The performance of the proposed system shows excellent results in controlling and monitoring air quality, temperature, and humidity compared with a previous version due to an increased range between the minimum and maximum values of the ventilation speed. Moreover, the ventilation DC motor of the fan in the proposed system runs at low speeds when necessary, which leads to lower power consumption compared to the previous version. This reduction is due to the membership function added to the ventilation speed of the fuzzy controller, which adapts the working time interval and room ventilation speed. A comparison of the new proposed system and previous version is conducted to identify the differences between the two and to highlight the effectiveness of the new model. © 2022, The Author(s), under exclusive licence to Springer-Verlag GmbH Germany, part of Springer Nature.},
	author_keywords = {Air quality; AQI; Fuzzy logic; Ventilation},
	keywords = {Computer circuits; Controllers; DC motors; Fuzzy logic; Health risks; Humidity control; Membership functions; Microcontrollers; Quality control; Speed; Ventilation; Wind; AQI; Control monitoring; Fuzzy-Logic; Healthy indoor environments; Indoor environment; Indoor pollution; Monitoring system; Outdoor pollutions; Surrounding environment; Temperature and humidities; Air quality},
	correspondence_address = {A. Bushnag; Faculty of Computers and Information Technology, University of Tabuk, Tabuk, Saudi Arabia; email: abushnag@ut.edu.sa},
	publisher = {Springer Science and Business Media Deutschland GmbH},
	issn = {18685137},
	language = {English},
	abbrev_source_title = {J. Ambient Intell. Humanized Comput.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 13}
}


